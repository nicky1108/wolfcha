.hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 0 10rpx;
}

.brand-mark {
  width: 112rpx;
  height: 112rpx;
  border: 2rpx solid rgba(197, 160, 89, 0.46);
  border-radius: 20rpx;
  background: linear-gradient(145deg, #8a1c1c, #b93636);
  color: #f0e6d2;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 58rpx;
  font-weight: 800;
  box-shadow: 0 18rpx 40rpx rgba(138, 28, 28, 0.22);
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.eyebrow {
  color: #8c7335;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  margin-top: 6rpx;
  color: #3d2e24;
  font-size: 46rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 8rpx;
  color: #6e5948;
  font-size: 25rpx;
  line-height: 1.55;
}

.button-row .wc-button {
  flex: 1;
  min-width: 190rpx;
}

.button-row {
  flex-wrap: wrap;
}
