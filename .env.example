ZENMUX_API_KEY=your_zenmux_api_key_here 
TOKENDANCE_API_KEY=your_tokendance_api_key_here
# 线上与本地内网 openHubs/New API 网关，服务端会调用 `${TOKENDANCE_BASE_URL}/chat/completions`
TOKENDANCE_BASE_URL=http://127.0.0.1:3000/v1
# MiniMax API 配置
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MINIMAX_API_BASE_URL=https://api.minimaxi.com
MINIMAX_TTS_MODEL=speech-01-turbo
MINIMAX_TTS_SPEED=1.2

# 自建数据库与登录会话配置
DATABASE_URL=postgres://user:password@host:5432/wolfcha
AUTH_SECRET=change_this_long_random_session_secret
DASHSCOPE_API_KEY=your_dashscope_api_key_here 
ADMIN_EMAILS=admin@example.com

# Vercel Analytics（仅 Vercel 平台或已配置兼容 /_vercel/insights 路由时开启）
ENABLE_VERCEL_ANALYTICS=false

# 静态音频 OSS/CDN 加速域名（可选，不填则继续走本站 /audio 与 /bgm）
NEXT_PUBLIC_AUDIO_ASSET_BASE_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com

# ZPAYZ 支付配置
ZPAYZ_PID=your_zpayz_pid_here
ZPAYZ_KEY=your_zpayz_key_here
ZPAYZ_BASE_URL=https://zpayz.cn
ZPAYZ_PAY_TYPE=alipay
ZPAYZ_PRICE_PER_CREDIT=1.00

# Stripe 配置（旧支付链路，保留用于回滚）
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PRICE_ID=your_stripe_price_id_here

# 观猹 OAuth2 配置（可选，配置后登录弹窗会显示观猹登录按钮）
NEXT_PUBLIC_WATCHA_CLIENT_ID=your_watcha_client_id_here
WATCHA_CLIENT_SECRET=your_watcha_client_secret_here

# Google OAuth2 配置（可选，配置后登录弹窗会显示 Google 登录按钮）
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

NEWAPI_API_KEY=your_newapi_api_key_here
NEWAPI_BASE_URL=your_newapi_url_here
